---
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');

const sectionOrder: Record<string, number> = { meta: 0, 'bible-reliability': 1 };
const sectionLabels: Record<string, string> = { meta: 'Site', 'bible-reliability': 'Bible Reliability' };

const sectionMap = new Map<string, typeof allArticles>();
for (const a of allArticles) {
  const s = a.data.section;
  if (!sectionMap.has(s)) sectionMap.set(s, []);
  sectionMap.get(s)!.push(a);
}

const sections = Array.from(sectionMap.entries())
  .sort(([a], [b]) => (sectionOrder[a] ?? 99) - (sectionOrder[b] ?? 99))
  .map(([key, items]) => ({
    key,
    label: sectionLabels[key] ?? key,
    items: items.sort((a, b) => a.data.order - b.data.order),
  }));

const currentPath = Astro.url.pathname;

function slugToHref(slug: string): string {
  return '/' + slug.split('/').join('/');
}
---

<!-- Desktop sidebar -->
<aside
  id="sidebar"
  class="hidden md:flex flex-col w-[15rem] shrink-0 border-r border-surface-100 dark:border-surface-800/80 min-h-[calc(100vh-3.25rem)] bg-surface-50/50 dark:bg-surface-950 pt-7 pb-16 overflow-y-auto sticky top-[3.25rem]"
  aria-label="Site navigation"
>
  <!-- Logo -->
  <div class="px-5 mb-8">
    <a href="/" class="group block">
      <span class="font-display text-[1.25rem] font-normal tracking-tight text-surface-900 dark:text-surface-50 group-hover:text-amber-700 dark:group-hover:text-amber-400 transition-colors leading-tight">
        Firm Ground
      </span>
      <p class="text-[0.65rem] font-sans text-surface-400 dark:text-surface-600 mt-0.5 tracking-wide uppercase">
        Apologetics Resource
      </p>
    </a>
  </div>

  <nav class="flex-1 px-3 space-y-6">
    {sections.map(({ key, label, items }) => (
      <div>
        {key !== 'meta' && (
          <p class="px-2 mb-2 text-[0.6rem] font-semibold uppercase tracking-[0.12em] text-surface-400 dark:text-surface-600 font-sans">
            {label}
          </p>
        )}
        <ul class="space-y-px">
          {items.map((item) => {
            const href = slugToHref(item.slug);
            const isActive = currentPath === href || currentPath === href + '/';
            const isParent = !isActive && currentPath.startsWith(href + '/');
            const isNested = !!item.data.subsection;
            return (
              <li>
                <a
                  href={href}
                  class:list={[
                    'flex items-center gap-2 rounded-lg font-sans transition-all leading-snug',
                    isNested ? 'ml-3 py-1 px-2 text-[0.75rem]' : 'py-1.5 px-2 text-[0.8rem]',
                    isActive
                      ? 'bg-amber-50 dark:bg-amber-900/15 text-amber-800 dark:text-amber-300 font-semibold'
                      : isParent
                      ? 'text-surface-700 dark:text-surface-300 font-medium'
                      : 'text-surface-500 dark:text-surface-500 hover:text-surface-800 dark:hover:text-surface-200 hover:bg-surface-100 dark:hover:bg-surface-800/60',
                  ]}
                  aria-current={isActive ? 'page' : undefined}
                >
                  {isActive && (
                    <span class="w-1 h-1 rounded-full bg-amber-500 shrink-0" aria-hidden="true" />
                  )}
                  {item.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}

    <!-- Coming soon -->
    <div class="opacity-35 pointer-events-none select-none">
      <p class="px-2 mb-2 text-[0.6rem] font-semibold uppercase tracking-[0.12em] text-surface-400 dark:text-surface-600 font-sans">
        Coming Soon
      </p>
      <ul class="space-y-px">
        {['Historical Jesus', 'The Resurrection', 'Prophecy', 'Archaeology'].map((s) => (
          <li>
            <span class="block py-1.5 px-2 text-[0.8rem] font-sans text-surface-400 dark:text-surface-600 rounded-lg">
              {s}
            </span>
          </li>
        ))}
      </ul>
    </div>
  </nav>

  <div class="px-5 pt-5 border-t border-surface-100 dark:border-surface-800 mt-4">
    <a href="/methodology" class="text-[0.7rem] font-sans text-surface-400 dark:text-surface-600 hover:text-surface-700 dark:hover:text-surface-300 transition-colors">
      Our methodology →
    </a>
  </div>
</aside>

<!-- Mobile FAB -->
<button
  id="sidebar-toggle"
  class="md:hidden fixed bottom-6 right-6 z-40 w-12 h-12 rounded-full bg-surface-900 dark:bg-surface-100 shadow-lg shadow-surface-900/20 flex items-center justify-center text-white dark:text-surface-900"
  aria-label="Toggle navigation"
  aria-expanded="false"
  aria-controls="mobile-sidebar"
>
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<!-- Mobile drawer -->
<div id="mobile-sidebar" class="md:hidden fixed inset-0 z-30 hidden" role="dialog" aria-label="Navigation">
  <div class="absolute inset-0 bg-surface-950/60 backdrop-blur-sm" id="mobile-overlay" />
  <div class="absolute left-0 top-0 bottom-0 w-72 bg-white dark:bg-surface-950 shadow-2xl overflow-y-auto p-5">
    <div class="flex items-center justify-between mb-7">
      <a href="/" class="font-display text-xl font-normal text-surface-900 dark:text-surface-50">Firm Ground</a>
      <button id="sidebar-close" class="p-1 text-surface-400" aria-label="Close menu">
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    {sections.map(({ key, label, items }) => (
      <div class="mb-5">
        {key !== 'meta' && (
          <p class="mb-2 text-[0.6rem] font-semibold uppercase tracking-[0.12em] text-surface-400 dark:text-surface-600 font-sans">{label}</p>
        )}
        <ul class="space-y-0.5">
          {items.map((item) => {
            const href = slugToHref(item.slug);
            const isActive = currentPath === href || currentPath === href + '/';
            return (
              <li>
                <a href={href} class:list={[
                  'block py-1.5 px-2 rounded-lg text-sm font-sans transition-colors',
                  item.data.subsection ? 'ml-3 text-xs' : '',
                  isActive
                    ? 'bg-amber-50 dark:bg-amber-900/15 text-amber-800 dark:text-amber-300 font-semibold'
                    : 'text-surface-500 dark:text-surface-500 hover:text-surface-800 dark:hover:text-surface-200',
                ]}>
                  {item.data.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))}
  </div>
</div>

<script>
  const toggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('mobile-sidebar');
  const overlay = document.getElementById('mobile-overlay');
  const closeBtn = document.getElementById('sidebar-close');

  const open  = () => { sidebar?.classList.remove('hidden'); toggle?.setAttribute('aria-expanded','true');  document.body.style.overflow = 'hidden'; };
  const close = () => { sidebar?.classList.add('hidden');    toggle?.setAttribute('aria-expanded','false'); document.body.style.overflow = ''; };

  toggle?.addEventListener('click', open);
  overlay?.addEventListener('click', close);
  closeBtn?.addEventListener('click', close);
</script>
