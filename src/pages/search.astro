---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Search"
  description="Search all articles on Firm Ground — manuscript evidence, textual criticism, Dead Sea Scrolls, and more."
>
  <div class="max-w-3xl mx-auto px-6 md:px-10 py-16">
    <h1 class="font-serif text-3xl font-bold text-ink-950 dark:text-parchment-50 mb-2">Search</h1>
    <p class="text-ink-500 dark:text-parchment-500 font-sans text-sm mb-8">
      Full-text search across all articles. You can also press <kbd class="font-mono text-xs bg-parchment-100 dark:bg-ink-800 border border-parchment-200 dark:border-ink-700 rounded px-1.5 py-0.5">⌘K</kbd> from anywhere.
    </p>

    <div id="search-container">
      <input
        id="search-input"
        type="search"
        placeholder="Search articles, manuscripts, topics…"
        autocomplete="off"
        class="w-full px-4 py-3 rounded-lg border border-parchment-200 dark:border-ink-700 bg-white dark:bg-ink-900 text-ink-900 dark:text-parchment-100 placeholder-ink-400 dark:placeholder-parchment-600 font-sans text-sm focus:outline-none focus:ring-2 focus:ring-gold-400 dark:focus:ring-gold-600 mb-6"
      />
      <div id="search-results" class="space-y-4" aria-live="polite" aria-label="Search results">
        <p class="text-sm text-ink-400 dark:text-parchment-600 font-sans">
          Enter a search term above. Search is available after running <code class="font-mono text-xs bg-parchment-100 dark:bg-ink-800 px-1 rounded">npm run build</code>.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  let pfLoaded = false;

  async function loadPagefind() {
    if (pfLoaded) return;
    try {
      // @ts-ignore
      const pf = await import('/pagefind/pagefind.js');
      await pf.init();
      window.pagefind = pf;
      pfLoaded = true;
    } catch {
      document.getElementById('search-results')!.innerHTML =
        '<p class="text-sm text-ink-400 dark:text-parchment-600 font-sans">Search not available in development mode. Run <code class="font-mono bg-parchment-100 dark:bg-ink-800 px-1 rounded">npm run build</code> first.</p>';
    }
  }

  const input = document.getElementById('search-input') as HTMLInputElement;
  const resultsEl = document.getElementById('search-results')!;

  let debounce: ReturnType<typeof setTimeout>;

  input?.addEventListener('focus', loadPagefind);
  input?.addEventListener('input', () => {
    clearTimeout(debounce);
    const q = input.value.trim();
    if (!q) { resultsEl.innerHTML = ''; return; }
    debounce = setTimeout(async () => {
      await loadPagefind();
      if (!window.pagefind) return;
      const res = await window.pagefind.search(q);
      if (!res.results.length) {
        resultsEl.innerHTML = `<p class="text-sm text-ink-400 dark:text-parchment-600 font-sans">No results for "<strong>${q}</strong>".</p>`;
        return;
      }
      const data = await Promise.all(res.results.slice(0, 12).map((r: any) => r.data()));
      resultsEl.innerHTML = data.map((r: any) => `
        <a href="${r.url}" class="block rounded-xl border border-parchment-200 dark:border-ink-800 bg-white dark:bg-ink-900 p-4 hover:border-gold-300 dark:hover:border-gold-700 transition-colors">
          <p class="font-sans font-semibold text-ink-800 dark:text-parchment-200 text-sm mb-1">${r.meta?.title ?? r.url}</p>
          <p class="font-sans text-xs text-ink-500 dark:text-parchment-500 leading-relaxed">${r.excerpt}</p>
        </a>
      `).join('');
    }, 200);
  });
</script>
