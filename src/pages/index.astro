---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Home"
  description="Firm Ground — a rigorous Christian apologetics resource for believers seeking foundation and skeptics seeking honest engagement."
>
  <div class="max-w-4xl mx-auto px-6 md:px-12 py-16 md:py-24">

    <!-- Hero -->
    <div class="mb-20">
      <p class="font-sans text-xs font-semibold uppercase tracking-[0.12em] text-amber-600 dark:text-amber-500 mb-6">
        Evidence-Based Apologetics
      </p>
      <h1 class="font-display font-normal text-4xl md:text-5xl lg:text-6xl text-surface-950 dark:text-surface-50 leading-[1.1] tracking-tight mb-6 text-balance">
        Christianity's claims,<br class="hidden md:block" />
        examined honestly.
      </h1>
      <p class="font-serif text-xl text-surface-500 dark:text-surface-400 leading-relaxed max-w-xl mb-10">
        For believers who want a stronger foundation. For skeptics who want straight answers.
        Primary sources, mainstream scholarship, hard questions addressed head-on.
      </p>
      <div class="flex flex-wrap gap-3">
        <a href="/bible-reliability" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-surface-950 dark:bg-surface-100 text-white dark:text-surface-950 font-sans font-semibold text-sm hover:bg-surface-800 dark:hover:bg-white transition-colors">
          Start with Bible Reliability
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
        <a href="/methodology" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-surface-200 dark:border-surface-700 text-surface-600 dark:text-surface-400 font-sans font-medium text-sm hover:bg-surface-50 dark:hover:bg-surface-900 transition-colors">
          Our methodology
        </a>
      </div>
    </div>

    <!-- Audiences -->
    <div class="grid md:grid-cols-2 gap-4 mb-20">
      <div class="rounded-2xl border border-surface-100 dark:border-surface-800 bg-surface-50 dark:bg-surface-900/60 p-6">
        <p class="text-xs font-sans font-semibold uppercase tracking-[0.1em] text-amber-600 dark:text-amber-500 mb-3">For Believers</p>
        <p class="font-serif text-surface-600 dark:text-surface-400 leading-relaxed text-[0.95rem]">
          You believe — but when a skeptic pushes back, you don't have an answer.
          Here you'll find evidence with primary sources, not just talking points.
        </p>
      </div>
      <div class="rounded-2xl border border-surface-100 dark:border-surface-800 bg-surface-50 dark:bg-surface-900/60 p-6">
        <p class="text-xs font-sans font-semibold uppercase tracking-[0.1em] text-blue-600 dark:text-blue-400 mb-3">For Skeptics</p>
        <p class="font-serif text-surface-600 dark:text-surface-400 leading-relaxed text-[0.95rem]">
          Someone sent you here. We've cited the scholars you respect and engaged
          the strongest version of the skeptical arguments — not the strawman.
        </p>
      </div>
    </div>

    <!-- Sections -->
    <div class="mb-20">
      <h2 class="font-display font-normal text-2xl text-surface-950 dark:text-surface-50 tracking-tight mb-6">Start Exploring</h2>
      <div class="grid sm:grid-cols-2 gap-3">
        <a href="/bible-reliability" class="group rounded-2xl border border-surface-200 dark:border-surface-800 bg-white dark:bg-surface-900 p-5 hover:border-amber-300 dark:hover:border-amber-700 hover:shadow-lg hover:shadow-amber-500/5 transition-all">
          <div class="flex items-start justify-between mb-3">
            <span class="font-display font-normal text-lg text-surface-950 dark:text-surface-50 group-hover:text-amber-700 dark:group-hover:text-amber-400 transition-colors leading-tight">
              Bible Reliability
            </span>
            <svg class="w-4 h-4 text-surface-300 dark:text-surface-700 group-hover:text-amber-500 transition-colors mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
          <p class="text-sm font-sans text-surface-500 dark:text-surface-500 leading-relaxed mb-3">
            Manuscript evidence, textual criticism, Dead Sea Scrolls, canonization — with interactive data visualizations.
          </p>
          <div class="flex flex-wrap gap-1.5">
            {['5,800+ manuscripts', '~30yr gap to P52', 'Ehrman & Wallace'].map((t) => (
              <span class="text-[10px] font-sans px-2 py-0.5 rounded-full bg-surface-100 dark:bg-surface-800 text-surface-500 dark:text-surface-500">
                {t}
              </span>
            ))}
          </div>
        </a>

        {[
          { name: 'Historical Jesus', desc: 'Non-Christian sources, dating of Gospels, eyewitness access.' },
          { name: 'The Resurrection', desc: 'The historical case for the most central Christian claim.' },
          { name: 'Fulfilled Prophecy', desc: 'Messianic prophecy, statistical arguments, honest objections.' },
          { name: 'Biblical Archaeology', desc: 'What the ground confirms — and what it doesn\'t.' },
        ].map((s) => (
          <div class="rounded-2xl border border-surface-100/60 dark:border-surface-800/40 bg-surface-50/50 dark:bg-surface-900/30 p-5 opacity-50">
            <div class="flex items-start justify-between mb-2">
              <span class="font-display font-normal text-lg text-surface-700 dark:text-surface-400">{s.name}</span>
              <span class="text-[10px] font-sans px-2 py-0.5 rounded-full bg-surface-200 dark:bg-surface-800 text-surface-400 dark:text-surface-600 shrink-0 mt-0.5">
                Soon
              </span>
            </div>
            <p class="text-xs font-sans text-surface-400 dark:text-surface-600">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- What this is not -->
    <div class="rounded-2xl border border-surface-100 dark:border-surface-800 p-6">
      <h2 class="font-sans text-xs font-semibold uppercase tracking-[0.1em] text-surface-400 dark:text-surface-600 mb-4">
        What this site is not
      </h2>
      <div class="grid sm:grid-cols-2 gap-x-8 gap-y-2 text-sm font-sans text-surface-500 dark:text-surface-500">
        {[
          'Proof that Christianity is true',
          'KJV-only or fringe apologetics',
          'A place that mocks skeptics',
          'Inflated or cherry-picked statistics',
          'Pretending all questions are settled',
          'Theological inerrancy arguments',
        ].map((item) => (
          <div class="flex items-baseline gap-2">
            <span class="text-surface-300 dark:text-surface-700 shrink-0">—</span>
            <span>{item}</span>
          </div>
        ))}
      </div>
    </div>

  </div>
</BaseLayout>
