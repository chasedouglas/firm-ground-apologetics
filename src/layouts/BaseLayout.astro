---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import DarkModeToggle from '../components/DarkModeToggle.tsx';
import SearchModal from '../components/SearchModal.tsx';

interface Props {
  title: string;
  description?: string;
  hideSidebar?: boolean;
}

const { title, description = 'A rigorous Christian apologetics resource for believers and skeptics.', hideSidebar = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://apologetics.fiveandtwo.co');
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Firm Ground</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${title} — Firm Ground`} />
  <meta property="og:description" content={description} />

  <!-- Fonts: DM Serif Display (headings) + Lora (body) + Plus Jakarta Sans (UI) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Lora:ital,wght@0,400..700;1,400..700&family=Plus+Jakarta+Sans:wght@300..700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Dark mode: prevent flash -->
  <script is:inline>
    (function() {
      var s = localStorage.getItem('theme');
      var p = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (s === 'dark' || (!s && p)) document.documentElement.classList.add('dark');
    })();
  </script>
</head>

<body class="bg-white dark:bg-surface-950 text-surface-800 dark:text-surface-200 font-sans antialiased">

  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-20 h-[3.25rem] glass border-b border-surface-200/80 dark:border-surface-800/80">
    <div class="flex items-center h-full px-4 gap-4 max-w-screen-2xl mx-auto">

      <!-- Mobile logo -->
      <a href="/" class="md:hidden font-display text-[1.1rem] font-normal text-surface-900 dark:text-surface-50 tracking-tight hover:text-amber-700 dark:hover:text-amber-400 transition-colors">
        Firm Ground
      </a>

      <!-- Breadcrumb slot (desktop) — filled by child pages if needed -->
      <div class="hidden md:flex items-center gap-1.5 text-xs font-sans text-surface-400 dark:text-surface-500 flex-1">
        <a href="/" class="hover:text-surface-700 dark:hover:text-surface-300 transition-colors">Firm Ground</a>
      </div>

      <div class="flex items-center gap-2 ml-auto">
        <SearchModal client:idle />
        <DarkModeToggle client:idle />
      </div>
    </div>
  </header>

  <div class="flex pt-[3.25rem] max-w-screen-2xl mx-auto">
    {!hideSidebar && <Sidebar />}
    <main class="flex-1 min-w-0">
      <slot />
    </main>
  </div>

</body>
</html>
