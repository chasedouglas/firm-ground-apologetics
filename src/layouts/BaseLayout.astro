---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import DarkModeToggle from '../components/DarkModeToggle.tsx';
import SearchModal from '../components/SearchModal.tsx';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'A rigorous Christian apologetics resource for believers and skeptics.', ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://apologetics.fiveandtwo.co');
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — Firm Ground</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={`${title} — Firm Ground`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  {ogImage && <meta property="og:image" content={ogImage} />}

  <!-- Fonts: Source Serif 4 (body) + DM Sans (UI) + JetBrains Mono (code) -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300..900;1,8..60,300..900&family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  <!-- Dark mode init (prevent flash) -->
  <script is:inline>
    (function() {
      var stored = localStorage.getItem('theme');
      var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      if (stored === 'dark' || (!stored && prefersDark)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>
</head>
<body class="bg-parchment-50 dark:bg-ink-950 text-ink-800 dark:text-parchment-200 font-sans antialiased">

  <!-- Top header bar -->
  <header class="fixed top-0 left-0 right-0 z-20 h-14 bg-parchment-50/95 dark:bg-ink-950/95 backdrop-blur border-b border-parchment-200 dark:border-ink-800 flex items-center">
    <div class="flex items-center gap-4 pl-4 pr-4 w-full max-w-screen-2xl mx-auto">
      <a href="/" class="font-serif font-bold text-base text-ink-900 dark:text-parchment-100 hover:text-gold-700 dark:hover:text-gold-400 transition-colors shrink-0 md:hidden">
        Firm Ground
      </a>
      <div class="flex-1" />
      <SearchModal client:idle />
      <DarkModeToggle client:idle />
    </div>
  </header>

  <div class="flex pt-14 max-w-screen-2xl mx-auto">
    <Sidebar />
    <main class="flex-1 min-w-0">
      <slot />
    </main>
  </div>

</body>
</html>
