---
import BaseLayout from './BaseLayout.astro';
import TableOfContents from '../components/TableOfContents.astro';

interface Source {
  id: string;
  author: string;
  title: string;
  publisher?: string;
  year?: number;
  url?: string;
  type: 'primary' | 'academic' | 'apologetic' | 'skeptical' | 'reference';
}

interface Props {
  title: string;
  description: string;
  lastUpdated: Date;
  sources: Source[];
  tags: string[];
  headings: Array<{ depth: number; slug: string; text: string }>;
}

const { title, description, lastUpdated, sources, tags, headings } = Astro.props;

const sourceTypeLabel: Record<string, string> = {
  primary:   'Primary',
  academic:  'Academic',
  apologetic:'Apologetic',
  skeptical: 'Skeptical',
  reference: 'Reference',
};
const sourceTypeDot: Record<string, string> = {
  primary:   'bg-blue-500',
  academic:  'bg-surface-400',
  apologetic:'bg-amber-500',
  skeptical: 'bg-violet-500',
  reference: 'bg-emerald-500',
};

const dateStr = lastUpdated.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description}>
  <div class="flex gap-12 px-8 md:px-12 xl:px-16 py-12 max-w-screen-xl">

    <!-- Article -->
    <article class="flex-1 min-w-0 max-w-[72ch]">

      <!-- Header -->
      <header class="mb-10 pb-10 border-b border-surface-100 dark:border-surface-800">
        <h1 class="font-display font-normal text-3xl md:text-[2.6rem] leading-[1.15] tracking-tight text-surface-950 dark:text-surface-50 mb-4">
          {title}
        </h1>
        <p class="font-serif text-[1.125rem] text-surface-500 dark:text-surface-400 leading-relaxed mb-5">
          {description}
        </p>
        <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-sans text-surface-400 dark:text-surface-500">
          <span>Updated {dateStr}</span>
          {tags.length > 0 && (
            <span class="flex flex-wrap gap-1.5">
              {tags.slice(0, 5).map((t) => (
                <span class="px-2 py-0.5 rounded-full bg-surface-100 dark:bg-surface-800 text-surface-500 dark:text-surface-400">
                  {t}
                </span>
              ))}
            </span>
          )}
        </div>
      </header>

      <!-- Body -->
      <div class="prose dark:prose-invert max-w-none">
        <slot />
      </div>

      <!-- Footnotes -->
      <section class="mt-16 pt-8 border-t border-surface-100 dark:border-surface-800" aria-label="Notes and citations">
        <p class="text-2xs font-sans font-semibold uppercase tracking-[0.1em] text-surface-400 dark:text-surface-600 mb-4">
          Notes &amp; Citations
        </p>
        <ol id="footnote-list" class="space-y-2 list-none pl-0 font-sans text-sm" />
      </section>

      <!-- Sources -->
      {sources.length > 0 && (
        <section class="mt-10 pt-8 border-t border-surface-100 dark:border-surface-800" aria-label="Sources cited">
          <p class="text-2xs font-sans font-semibold uppercase tracking-[0.1em] text-surface-400 dark:text-surface-600 mb-5">
            Sources Cited
          </p>
          <ul class="space-y-3 font-sans">
            {sources.map((s) => (
              <li class="flex items-start gap-3 text-sm">
                <span class={`mt-1.5 w-1.5 h-1.5 rounded-full shrink-0 ${sourceTypeDot[s.type]}`} aria-label={sourceTypeLabel[s.type]} />
                <span class="text-surface-600 dark:text-surface-400 leading-relaxed">
                  <span class="font-medium text-surface-800 dark:text-surface-200">{s.author}</span>.{' '}
                  <em>{s.title}</em>.{' '}
                  {s.publisher && <span class="text-surface-500">{s.publisher}, </span>}
                  {s.year && <span class="text-surface-500">{s.year}.</span>}
                  {s.url && (
                    <a href={s.url} target="_blank" rel="noopener noreferrer"
                      class="ml-1.5 text-amber-700 dark:text-amber-400 text-xs">
                      Link →
                    </a>
                  )}
                </span>
              </li>
            ))}
          </ul>
          <div class="mt-5 flex flex-wrap gap-x-4 gap-y-1 text-2xs font-sans text-surface-400">
            {(['primary','academic','apologetic','skeptical','reference'] as const).map((t) => (
              <span class="flex items-center gap-1.5">
                <span class={`w-1.5 h-1.5 rounded-full ${sourceTypeDot[t]}`} />
                {sourceTypeLabel[t]}
              </span>
            ))}
          </div>
        </section>
      )}
    </article>

    <!-- TOC -->
    <aside class="shrink-0 w-48 hidden xl:block">
      <TableOfContents headings={headings} />
    </aside>
  </div>
</BaseLayout>
